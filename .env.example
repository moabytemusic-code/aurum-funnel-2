# Video Configuration
# Replace with your actual video ID
NEXT_PUBLIC_VIDEO_PLATFORM=youtube
NEXT_PUBLIC_VIDEO_ID=YOUR_VIDEO_ID_HERE

# Support Contact Info
NEXT_PUBLIC_SUPPORT_EMAIL=support@theaifinancebreakdown.com
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/YOUR_LINK

# Brevo (Sendinblue) API Configuration
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key-here
BREVO_LIST_ID=your-list-id-here

# Brevo Email Sender Configuration
# Must be a verified sender in Brevo: https://app.brevo.com/senders
BREVO_SENDER_EMAIL=noreply@aurumpathway.com
BREVO_SENDER_NAME=Aurum Pathway

# Booking URL for email CTA button
# Falls back to NEXT_PUBLIC_BOOKING_URL if not set
BREVO_BOOKING_URL=https://calendly.com/YOUR_LINK

# Admin Dashboard Password
# Change this to your own secure password
NEXT_PUBLIC_ADMIN_PASSWORD=aurum2026
